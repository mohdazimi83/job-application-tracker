# ============================================================
# application.properties.example
# Copy this to application.properties and fill in real values.
# Never commit application.properties with real credentials.
# ============================================================

spring.application.name=job-application-tracker

# MySQL Database Connection
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:mysql://localhost:3306/job_tracker_db}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:your_db_username}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:your_db_password}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA / Hibernate Properties
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# Gemini API Key — get one from https://aistudio.google.com/app/apikey
gemini.api.key=${GEMINI_API_KEY:your_gemini_api_key_here}
gemini.api.model=${GEMINI_API_MODEL:gemini-2.5-flash}

# Additional Config
spring.jpa.open-in-view=false
spring.sql.init.mode=never
logging.level.com.example.jobapplicationtracker=DEBUG

# Server Port — Railway injects PORT automatically
server.port=${PORT:8080}
